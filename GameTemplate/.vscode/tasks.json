{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with MSBuild",
            "type": "shell",
            "command": "C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\MSBuild\\Current\\Bin\\MSBuild.exe",
            "args": [
                "${workspaceFolder}/Game/Game.sln", 
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/t:Build",
                "/p:AdditionalOptions=/ignore:4099"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        }
    ]
}